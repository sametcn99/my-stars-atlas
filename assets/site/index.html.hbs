<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{site.fullTitle}}</title>
    <meta name="description" content="{{site.seo.description}}" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="color-scheme" content="dark" />
    <meta name="robots" content="index,follow" />
    <meta property="og:type" content="{{site.seo.ogType}}" />
    <meta property="og:title" content="{{site.seo.ogTitle}}" />
    <meta property="og:description" content="{{site.seo.ogDescription}}" />
    <meta property="og:image" content="{{{site.seo.imageUrl}}}" />
    <meta property="og:url" content="./" />
    <meta property="og:site_name" content="{{site.seo.siteName}}" />
    <meta name="twitter:card" content="{{site.seo.twitterCard}}" />
    <meta name="twitter:title" content="{{site.seo.twitterTitle}}" />
    <meta name="twitter:description" content="{{site.seo.twitterDescription}}" />
    <meta name="twitter:image" content="{{{site.seo.imageUrl}}}" />
    <link rel="canonical" href="./" />
    <link rel="icon" type="image/png" sizes="192x192" href="{{{site.manifest.icons.[0].src}}}" />
    <link rel="apple-touch-icon" href="{{{site.manifest.icons.[0].src}}}" />
    <link rel="manifest" href="./manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="./styles.css" />
  </head>
  <body>
    <a class="skip-link" href="#results">Skip to results</a>

    <div class="page-shell">
      <header class="hero-section">
        <div class="container-xxl hero-grid">
          <div class="hero-copy surface-panel surface-panel-lg">
            <p class="eyebrow">Static GitHub Pages catalog</p>
            <h1 id="page-title">{{site.heroTitle}}</h1>
            <p id="page-description" class="hero-description">{{site.heroDescription}}</p>

            <div class="hero-meta" aria-label="Catalog metrics">
              <div class="metric-tile">
                <span class="metric-label">Repos loaded</span>
                <strong id="loaded-count">0</strong>
              </div>
              <div class="metric-tile">
                <span class="metric-label">Total repos</span>
                <strong id="total-count">0</strong>
              </div>
              <div class="metric-tile">
                <span class="metric-label">Updated</span>
                <strong id="generated-at">Waiting</strong>
              </div>
            </div>

            <div class="hero-actions">
              <a class="btn atlas-btn-primary" href="{{{github.profileUrl}}}" target="_blank" rel="noreferrer noopener">
                {{site.profileLinkLabel}}
              </a>
            </div>
          </div>

        </div>
      </header>

      <main class="container-xxl pb-5" id="results">
        <section class="controls-section surface-panel" aria-labelledby="controls-title">
          <div class="section-head">
            <div>
              <p class="eyebrow">Controls</p>
              <h2 id="controls-title">Search, filter, and sort</h2>
            </div>
          </div>

          <div class="row g-3 align-items-end controls-grid">
            <div class="col-12 col-xl-4">
              <label class="form-label text-uppercase tiny-label" for="search-input">Search repositories</label>
              <input
                class="form-control atlas-input"
                id="search-input"
                type="search"
                placeholder="Search by name, topic, language, description"
                autocomplete="off"
                spellcheck="false"
              />
            </div>
            <div class="col-6 col-md-4 col-xl-2">
              <label class="form-label text-uppercase tiny-label" for="sort-select">Sort by</label>
              <select class="form-select atlas-select" id="sort-select">
                <option value="starred-desc">Recently starred</option>
                <option value="stars-desc">Most stars</option>
                <option value="updated-desc">Recently updated</option>
                <option value="name-asc">Repository name</option>
              </select>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
              <label class="form-label text-uppercase tiny-label" for="visibility-select">Visibility</label>
              <select class="form-select atlas-select" id="visibility-select">
                <option value="all">All repos</option>
                <option value="active">Active only</option>
                <option value="archived">Archived only</option>
              </select>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
              <label class="form-label text-uppercase tiny-label" for="language-select">Language</label>
              <select class="form-select atlas-select" id="language-select">
                <option value="all">All languages</option>
              </select>
            </div>
            <div class="col-6 col-md-4 col-xl-2">
              <label class="form-label text-uppercase tiny-label" for="license-select">License</label>
              <select class="form-select atlas-select" id="license-select">
                <option value="all">All licenses</option>
              </select>
            </div>
          </div>

          <div class="active-summary" id="active-summary">Preparing filters.</div>
        </section>

        <section class="category-nav surface-panel" aria-labelledby="category-nav-title">
          <div class="section-head compact-head">
            <div>
              <p class="eyebrow">Categories</p>
              <h2 id="category-nav-title">Jump between sections</h2>
            </div>
          </div>
          <div class="pill-row" id="category-pills" role="tablist" aria-label="Category filters"></div>
        </section>

        <section aria-labelledby="section-title" class="results-shell">
          <div class="results-header">
            <div>
              <p class="eyebrow">Results</p>
              <h2 id="section-title">Repositories by category</h2>
            </div>
          </div>

          <div class="empty-state surface-panel d-none" id="empty-state">
            <h3>No repositories matched.</h3>
            <p>Try a broader search, switch category, or reset the archived filter.</p>
          </div>

          <div id="sections-root" class="sections-root"></div>
          <div class="load-sentinel" id="load-sentinel" aria-hidden="true"></div>
        </section>
      </main>
    </div>

    <noscript>
      <div class="noscript-banner">This catalog needs JavaScript to progressively load repository chunks.</div>
    </noscript>

    <script type="module" src="./app.js"></script>
  </body>
</html>